# ─── お問い合わせフォーム メール送信設定 ──────────────────────────────
# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# Vercel にデプロイする場合は、Vercel ダッシュボードの Environment Variables に設定してください。

# SMTP サーバー設定
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password

# 問い合わせ受信先メールアドレス（必ずこの値に設定してください）
CONTACT_TO_EMAIL=homiya@houmiyasetubi.com
